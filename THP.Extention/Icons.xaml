<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <BitmapImage x:Key="Report" UriSource="pack://application:,,,/THP.Extention;component/Resources/Report.png" />

    <Style x:Key="BugHistoryRowStyle" TargetType="DataGridRow" BasedOn="{StaticResource DataGrid_RowStyle}">
        <Style.Triggers>
            <DataTrigger Binding="{Binding Item.IsChecked}" Value="True">
                <Setter Property="Background" Value="#FFFFC8C8" />
            </DataTrigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>
